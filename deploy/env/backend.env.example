# Spring
SERVER_PORT=18080
DB_URL=jdbc:postgresql://127.0.0.1:5432/interview_online_codex
DB_USER=interview
DB_PASSWORD=change-me
CORS_ORIGINS=https://interview.domiknote.ru

# Agent sync (optional)
AGENT_LINEAR_SYNC_ENABLED=false
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql

# Code execution mode
EXECUTION_MODE=local
EXECUTION_LOCAL_ENABLED=true
EXECUTION_ISOLATED_URL=http://127.0.0.1:7070/api/execute
EXECUTION_FALLBACK_TO_LOCAL=false
EXECUTION_KILL_SWITCH=false

# Observability (optional)
AGENT_LANGFUSE_ENABLED=false
AGENT_LANGFUSE_URL=
AGENT_LANGFUSE_API_KEY=
