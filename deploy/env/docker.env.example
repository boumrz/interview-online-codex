# Copy to server:
#   sudo mkdir -p /etc/interview-online
#   sudo cp deploy/env/docker.env.example /etc/interview-online/.env
#   sudo nano /etc/interview-online/.env
#   sudo chown root:romazh /etc/interview-online/.env
#   sudo chmod 640 /etc/interview-online/.env

DOMAIN=interview.vtools.tech
INTERVIEW_SERVER_NAMES=interview.vtools.tech,interview.domiknote.ru
HTTP_PORT=80
HTTPS_PORT=443
NGINX_SSL=false

# Enable with docker-compose.shared-proxy.yml after the domiknote.ru certificate exists.
FINANCE_PROXY_ENABLED=false
FINANCE_DOMAIN=domiknote.ru
FINANCE_CERT_DOMAIN=domiknote.ru
FINANCE_WEB_UPSTREAM=finance-assistant-web-1:80
SHARED_PROXY_NETWORK=domiknote_proxy

DB_NAME=interview_online
DB_USER=interview
DB_PASSWORD=change-me

CORS_ORIGINS=https://interview.vtools.tech,https://interview.domiknote.ru

# Required before init_ssl_docker.sh
CERTBOT_EMAIL=admin@example.com
# Comma or space separated. The first name becomes the live certificate folder.
CERTBOT_DOMAINS=interview.vtools.tech,interview.domiknote.ru

# Use both files when interview-online-web should proxy domiknote.ru too:
# COMPOSE_FILES=/opt/interview-online/repo/docker-compose.prod.yml:/opt/interview-online/repo/docker-compose.shared-proxy.yml

# Optional agent integrations
AGENT_LINEAR_SYNC_ENABLED=false
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql
AGENT_LANGFUSE_ENABLED=false
AGENT_LANGFUSE_URL=
AGENT_LANGFUSE_API_KEY=
